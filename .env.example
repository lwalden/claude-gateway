# Port the gateway listens on
PORT=3131

# Bearer token callers must send in Authorization header
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_API_KEY=your-secret-key-here

# Anthropic API key — used as fallback when Claude CLI is unavailable
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for API fallback calls
# Defaults to claude-opus-4-6 if not set
ANTHROPIC_MODEL=claude-opus-4-6

# Timeout in ms before giving up on CLI and falling back to API (default: 30000)
CLI_TIMEOUT_MS=30000

# Set to "false" to disable Anthropic API fallback when CLI fails (returns 503 instead)
API_FALLBACK_ENABLED=true
